const cv = $input.first().json.containerVersion;

if (!cv) {
  throw new Error('containerVersion not found');
}

const tags = (cv.tag || []).map(tag => {
  const params = {};

  (tag.parameter || []).forEach(p => {
    params[p.key] = p.value;
  });

  return {
    id: tag.tagId,
    name: tag.name,
    type: tag.type,
    params,
    trigger_ids: tag.firingTriggerId || [],
    folderId: tag.parentFolderId || null,
    isPaused: tag.paused || false,
    consentStatus: tag.consentSettings?.consentStatus || "NOT_SET"
  };
});

const triggers = (cv.trigger || []).map(t => ({
  id: t.triggerId,
  name: t.name,
  type: t.type
}));

const variables = (cv.variable || []).map(v => ({
  id: v.variableId,
  name: v.name,
  type: v.type
}));

// FIXED
const ga4ConfigTags = tags.filter(
  t => ["googtag", "gaawc"].includes(t.type)
);

const ga4EventTags = tags.filter(
  t => t.type === "gaawe"
);

const orphanedTags = tags.filter(
  t => t.trigger_ids.length === 0
);

const allFiringIds = new Set(
  tags.flatMap(t => t.trigger_ids)
);

const orphanedTriggers = triggers.filter(
  t => !allFiringIds.has(t.id)
);

const allParamValues = tags.flatMap(
  t => Object.values(t.params)
    .filter(Boolean)
    .map(String)
);

const unusedVariables = variables.filter(
  v =>
    !allParamValues.some(val =>
      val.includes(`{{${v.name}}}`)
    )
);

const ecommerceEventNames = ga4EventTags
  .map(t => t.params.eventName)
  .filter(Boolean);

return [{
  json: {
    container_name: cv.container?.name || "unknown",
    container_id: cv.container?.publicId || "unknown",

    signals: {
      totalTags: tags.length,
      totalTriggers: triggers.length,
      totalVariables: variables.length,

      ga4ConfigTagCount: ga4ConfigTags.length,
      ga4EventTagCount: ga4EventTags.length,

      orphanedTagCount: orphanedTags.length,
      orphanedTriggerCount: orphanedTriggers.length,

      unusedVariableCount: unusedVariables.length,

      customHtmlTagCount: tags.filter(
        t => t.type === "html"
      ).length,

      consentNotSetCount: tags.filter(
        t => t.consentStatus === "NOT_SET"
      ).length,

      duplicateGA4ConfigRisk:
        ga4ConfigTags.length > 1,

      ecommerceEventNames
    },

    orphanedTags: orphanedTags.map(t => ({
      id: t.id,
      name: t.name
    })),

    orphanedTriggers: orphanedTriggers.map(t => ({
      id: t.id,
      name: t.name
    })),

    unusedVariables: unusedVariables.map(v => ({
      id: v.id,
      name: v.name
    }))
  }
}];
